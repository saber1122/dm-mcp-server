{
  "_comment": "将此文件复制到项目根目录，重命名为 dm-mcp-config.json，然后修改连接信息",
  "dm": {
    "jarPath": "/opt/dmdbms/drivers/jdbc/DmJdbcDriver18.jar",
    "_jarPath_comment": "也支持相对路径，相对于本配置文件所在目录，如: ./drivers/DmJdbcDriver18.jar",
    "javaHome": "/usr/lib/jvm/java-17-openjdk",
    "_javaHome_comment": "可选。也可通过 .mcp.json 的 env.JAVA_HOME 设置，优先级: 配置文件 > 环境变量",
    "host": "127.0.0.1",
    "port": 5236,
    "database": "DAMENG",
    "username": "SYSDBA",
    "password": "SYSDBA001",
    "schema": "SYSDBA",
    "jdbcParams": {
      "compatibleMode": "mysql",
      "characterEncoding": "UTF-8",
      "useUnicode": "true",
      "useSSL": "false",
      "tinyInt1isBit": "false",
      "allowPublicKeyRetrieval": "true",
      "serverTimezone": "Asia/Shanghai",
      "clobAsString": "true",
      "loginTimeout": "30",
      "socketTimeout": "60000"
    },
    "connectionPool": {
      "min": 1,
      "max": 10,
      "idleTimeoutMs": 30000
    }
  },
  "permission": {
    "mode": "readonly",
    "allowedSchemas": ["SYSDBA"],
    "blockedTables": ["SYS_USER", "SYS_PRIVS", "SYS_AUDIT"],
    "maxResultRows": 500,
    "enableExplain": true,
    "requireConfirmForDDL": true
  },
  "server": {
    "name": "dm-mcp",
    "version": "1.0.0",
    "logLevel": "info"
  }
}
